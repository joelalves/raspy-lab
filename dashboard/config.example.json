{
  "refreshIntervalSeconds": 10,
  "dockerAgent": {
    "url": "http://SERVER_PI_IP:9090",
    "apiKey": "change-me-to-a-long-random-string"
  },
  "jenkins": {
    "url": "http://SERVER_PI_IP:8080",
    "user": "your-jenkins-user",
    "apiToken": "your-jenkins-api-token"
  },
  "sonarqube": {
    "url": "http://SERVER_PI_IP:9000",
    "token": "your-sonarqube-user-token"
  },
  "weather": {
    "location": "Lisbon, Portugal",
    "refreshIntervalMinutes": 30
  },
  "pihole": {
    "url": "http://SERVER_PI_IP",
    "password": "your-pihole-admin-password"
  },
  "shelly": {
    "url": "http://SHELLY_DEVICE_IP",
    "carbonIntensityGramsPerKwh": 200
  },
  "bluetooth": {
    "mac": "AA:BB:CC:DD:EE:FF"
  },
  "spotify": {
    "clientId": "your-spotify-app-client-id",
    "clientSecret": "your-spotify-app-client-secret",
    "_comment": "Spotify requires this to be HTTPS or exactly http://127.0.0.1:<port>/... (loopback literal, not 'localhost' or a LAN IP) - so the one-time login has to be done in a browser running on the touchscreen Pi itself, not a phone/laptop.",
    "redirectUri": "http://127.0.0.1:8080/api/spotify/callback"
  },
  "notifications": {
    "ntfyUrl": "https://ntfy.sh/your-unique-topic-name"
  }
}

